outcome_data = read_csv(here("Data_Used", "FORVIDIT_AllOutcomes.csv")) |>
mutate(id = hhidpn) |>
dplyr::select(-c(1,2))
sex_data = read_dta(here("Data_Used", "Hrs_h.dta"))|>
mutate(id = as.double(hhidpn)) |>
mutate(PAGE = age_baseline) |>
mutate(Female = ifelse(sex == "Female", 1, 0))|>
dplyr::select(id, Female, PAGE)
outcome_data = inner_join(sex_data, outcome_data, by = "id")
head(outcome_data)
con_dat = read_csv(here("Data_Created", "hrsPoA_sex65.csv")) |>
dplyr::select(id, Theta_1, paceofaging, hrsPoA) |>
rename(theta = Theta_1) |>
mutate(theta = scale(theta)) |>
rename(poa = paceofaging) |>
mutate(poa = scale(poa)) |>
rename(theta_ratio = hrsPoA) |>
mutate(theta_ratio = scale(theta_ratio))
con_dat2 = read_csv(here("Data_Created", "HRSPoAV2_Mortality.csv")) |>
rename(theta_ratio_gn = hrsPoA) |>
mutate(theta_ratio_gn = scale(theta_ratio_gn))
construct_4way = inner_join(con_dat , con_dat2, by = "id")
head(construct_4way)
write.csv(construct_4way, file= "Data_Created/construct_4way.csv")
survival_data <- inner_join(construct_4way, outcome_data, by = "id")
#survival_data$Race <- as.factor(survival_data$Race) - not needed rn
survival_data$Female <- as.factor(survival_data$Female)
#survival_data$Ethnicity <- as.factor(survival_data$Ethnicity) - not needed rn
# Create age-residualized, scaled versions
survival_data <- survival_data |>
mutate(
# Age-residualized poa
poa_resid = scale(residuals(lm(poa ~ PAGE, data = survival_data, na.action = na.exclude))),
# Age-residualized theta
theta_resid = scale(residuals(lm(theta ~ PAGE, data = survival_data, na.action = na.exclude))),
# Age-residualized theta_ratio
theta_ratio_resid = scale(residuals(lm(theta_ratio ~ PAGE, data = survival_data, na.action = na.exclude))),
# Age-residualized theta_ratio_gn
theta_ratio_gn_resid = scale(residuals(lm(theta_ratio_gn ~ PAGE, data = survival_data, na.action = na.exclude)))
)
# Assess HRS results
