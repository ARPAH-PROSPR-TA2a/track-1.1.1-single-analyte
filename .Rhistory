}
if (!is.null(results_dnam$filtered$all$treatment_effects)) {
te_filt <- results_dnam$filtered$all$treatment_effects
cat("  Treatment effects: ", nrow(te_filt), " rows\n\n")
}
cat("Validation Checks (DNAm Dual Probe Sets)\n")
# Get analyte counts for comparison
full_analytes <- if (!is.null(results_dnam$full$all$coefficients)) length(unique(results_dnam$full$all$coefficients$ANALYTE_NAME)) else 0
filtered_analytes <- if (!is.null(results_dnam$filtered$all$coefficients)) length(unique(results_dnam$filtered$all$coefficients$ANALYTE_NAME)) else 0
checks_dnam <- list(
"Has 'full' key" = "full" %in% names(results_dnam),
"Has 'filtered' key" = "filtered" %in% names(results_dnam),
"Full has all/male/female" = all(c("all", "male", "female") %in% names(results_dnam$full)),
"Filtered has all/male/female" = all(c("all", "male", "female") %in% names(results_dnam$filtered)),
"Full coefficients exist" = !is.null(results_dnam$full$all$coefficients),
"Filtered coefficients exist" = !is.null(results_dnam$filtered$all$coefficients),
"Full has expected rows" = nrow(results_dnam$full$all$coefficients) > 0,
"Filtered has expected rows" = nrow(results_dnam$filtered$all$coefficients) > 0,
"Filtered <= Full analytes" = filtered_analytes <= full_analytes,
"Full has effect sizes" = all(!is.na(results_dnam$full$all$coefficients$EFFECT_SIZE)),
"Filtered has effect sizes" = all(!is.na(results_dnam$filtered$all$coefficients$EFFECT_SIZE)),
"Full coef has BH correction" = "BH_P_VALUE" %in% colnames(results_dnam$full$all$coefficients),
"Filtered coef has BH correction" = "BH_P_VALUE" %in% colnames(results_dnam$filtered$all$coefficients),
"Full treatment effects exist" = !is.null(results_dnam$full$all$treatment_effects),
"Filtered treatment effects exist" = !is.null(results_dnam$filtered$all$treatment_effects),
"Full TE has BH correction" = "BH_P_VALUE" %in% colnames(results_dnam$full$all$treatment_effects),
"Filtered TE has BH correction" = "BH_P_VALUE" %in% colnames(results_dnam$filtered$all$treatment_effects),
"Full TE FU levels correct" = all(sort(unique(results_dnam$full$all$treatment_effects$FU)) %in% c(1, 2)),
"Full sex stratification" = !is.null(results_dnam$full$male$coefficients) && !is.null(results_dnam$full$female$coefficients),
"Filtered sex stratification" = !is.null(results_dnam$filtered$male$coefficients) && !is.null(results_dnam$filtered$female$coefficients)
)
dnam_pass <- TRUE
for (name in names(checks_dnam)) {
status <- if (checks_dnam[[name]]) "PASS" else "FAIL"
cat(status, " ", name, "\n", sep="")
if (!checks_dnam[[name]]) dnam_pass <- FALSE
}
cat("\n")
# Validate treatment effects are computed correctly (DNAm/LIMMA)
cat("Treatment Effect Validation (DNAm/LIMMA)\n")
coefs <- results_dnam$full$all$coefficients
te <- results_dnam$full$all$treatment_effects
# Pick a sample analyte
sample_analyte <- te$ANALYTE_NAME[1]
te_analyte <- te[te$ANALYTE_NAME == sample_analyte, ]
coefs_analyte <- coefs[coefs$ANALYTE_NAME == sample_analyte, ]
# Get relevant coefficients (LIMMA uses FU_factor naming)
ctrl_coef <- coefs_analyte[grepl("^CONTROL_STATUS[0-9]*$", coefs_analyte$COEFFICIENT), ]
interaction_coef <- coefs_analyte[grepl("CONTROL_STATUS.*:.*FU", coefs_analyte$COEFFICIENT), ]
# Treatment effect at FU=1 should match CONTROL_STATUS coefficient
te_fu1 <- te_analyte[te_analyte$FU == 1, ]
effect_fu1_expected <- ctrl_coef$EFFECT_SIZE
# Treatment effect at FU=2 should equal CONTROL_STATUS + interaction
te_fu2 <- te_analyte[te_analyte$FU == 2, ]
effect_fu2_expected <- ctrl_coef$EFFECT_SIZE + interaction_coef$EFFECT_SIZE
# Naive SE for comparison
naive_se_fu2 <- sqrt(ctrl_coef$SE^2 + interaction_coef$SE^2)
cat("  Sample analyte: ", sample_analyte, "\n")
cat("  FU=1: contrasts.fit=", round(te_fu1$EFFECT_SIZE, 6), " expected=", round(effect_fu1_expected, 6), "\n")
cat("  FU=2: contrasts.fit=", round(te_fu2$EFFECT_SIZE, 6), " expected=", round(effect_fu2_expected, 6), "\n")
cat("  FU=2 SE: contrasts.fit=", round(te_fu2$SE, 6), " naive=", round(naive_se_fu2, 6), "\n\n")
te_validation_dnam <- list(
"FU=1 effect matches CONTROL_STATUS" = abs(te_fu1$EFFECT_SIZE - effect_fu1_expected) < 1e-6,
"FU=2 effect matches coefficient sum" = abs(te_fu2$EFFECT_SIZE - effect_fu2_expected) < 1e-6,
"FU=2 SE differs from naive (uses covariance)" = abs(te_fu2$SE - naive_se_fu2) > 1e-10
)
for (name in names(te_validation_dnam)) {
status <- if (te_validation_dnam[[name]]) "PASS" else "FAIL"
cat(status, " ", name, "\n", sep="")
if (!te_validation_dnam[[name]]) dnam_pass <- FALSE
}
cat("\n")
# ===== TEST 4: DNAm WITH SINGLE FU (EDGE CASE) =====
cat("TEST 4: DNAm Analysis with Dual Probe Sets (Single FU)\n")
cat("======================================================\n\n")
# Use single FU pheno data
pheno_dnam_single <- pheno_lm
cat("Running DNAm Analysis with Single FU (expects warnings about missing probes)\n")
results_dnam_single <- FAST_omics_WAS(
pheno = pheno_dnam_single,
omics = omics,
omics_type = "DNAm",
additional_covariates = additional_covariates
)
cat("\nResults Structure (DNAm Single FU)\n")
cat("  Top-level keys: ", paste(names(results_dnam_single), collapse=", "), "\n\n")
cat("Validation Checks (DNAm Single FU)\n")
checks_dnam_single <- list(
"Has 'full' key" = "full" %in% names(results_dnam_single),
"Has 'filtered' key" = "filtered" %in% names(results_dnam_single),
"Full coefficients exist" = !is.null(results_dnam_single$full$all$coefficients),
"Filtered coefficients exist" = !is.null(results_dnam_single$filtered$all$coefficients),
"Full coef has BH correction" = "BH_P_VALUE" %in% colnames(results_dnam_single$full$all$coefficients),
"Filtered coef has BH correction" = "BH_P_VALUE" %in% colnames(results_dnam_single$filtered$all$coefficients),
"Full treatment effects exist" = !is.null(results_dnam_single$full$all$treatment_effects),
"Full TE FU level is 1" = all(results_dnam_single$full$all$treatment_effects$FU == 1),
"Full TE has BH correction" = "BH_P_VALUE" %in% colnames(results_dnam_single$full$all$treatment_effects)
)
dnam_single_pass <- TRUE
for (name in names(checks_dnam_single)) {
status <- if (checks_dnam_single[[name]]) "PASS" else "FAIL"
cat(status, " ", name, "\n", sep="")
if (!checks_dnam_single[[name]]) dnam_single_pass <- FALSE
}
cat("\n")
# ===== SUMMARY =====
cat("Summary\n")
cat("=======\n\n")
cat("Test Results:\n")
cat("  LM (Single FU, Proteomics):      ", if (lm_pass) "PASS" else "FAIL", "\n")
cat("  LME4 (Multiple FU, Proteomics):  ", if (lme4_pass) "PASS" else "FAIL", "\n")
cat("  DNAm Dual Probe Sets (Multi FU): ", if (dnam_pass) "PASS" else "FAIL", "\n")
cat("  DNAm Dual Probe Sets (Single FU):", if (dnam_single_pass) "PASS" else "FAIL", "\n\n")
all_pass <- lm_pass && lme4_pass && dnam_pass && dnam_single_pass
if (all_pass) {
cat("ALL TESTS PASSED\n")
} else {
cat("SOME TESTS FAILED\n")
}
