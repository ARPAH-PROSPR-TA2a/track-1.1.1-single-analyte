if (!checks_lme4[[name]]) lme4_pass <- FALSE
}
cat("\n")
# Validate treatment effects are computed correctly (LME4)
cat("Treatment Effect Validation (LME4)\n")
coefs <- results_lme4$all$coefficients
te <- results_lme4$all$treatment_effects
# Pick a sample analyte
sample_analyte <- te$ANALYTE_NAME[1]
te_analyte <- te[te$ANALYTE_NAME == sample_analyte, ]
coefs_analyte <- coefs[coefs$ANALYTE_NAME == sample_analyte, ]
# Get relevant coefficients
ctrl_coef <- coefs_analyte[grepl("^CONTROL_STATUS[0-9]*$", coefs_analyte$COEFFICIENT), ]
interaction_coef <- coefs_analyte[grepl("CONTROL_STATUS.*:.*FU2", coefs_analyte$COEFFICIENT), ]
# Treatment effect at FU=1 should match CONTROL_STATUS coefficient
te_fu1 <- te_analyte[te_analyte$FU == 1, ]
effect_fu1_expected <- ctrl_coef$EFFECT_SIZE
# Treatment effect at FU=2 should equal CONTROL_STATUS + CONTROL_STATUS:FU2
te_fu2 <- te_analyte[te_analyte$FU == 2, ]
effect_fu2_expected <- ctrl_coef$EFFECT_SIZE + interaction_coef$EFFECT_SIZE
# Naive SE (assuming independence) for comparison
naive_se_fu2 <- sqrt(ctrl_coef$SE^2 + interaction_coef$SE^2)
cat("  Sample analyte: ", sample_analyte, "\n")
cat("  FU=1: emmeans=", round(te_fu1$EFFECT_SIZE, 6), " expected=", round(effect_fu1_expected, 6), "\n")
cat("  FU=2: emmeans=", round(te_fu2$EFFECT_SIZE, 6), " expected=", round(effect_fu2_expected, 6), "\n")
cat("  FU=2 SE: emmeans=", round(te_fu2$SE, 6), " naive=", round(naive_se_fu2, 6), "\n\n")
te_validation_lme4 <- list(
"FU=1 effect matches CONTROL_STATUS" = abs(te_fu1$EFFECT_SIZE - effect_fu1_expected) < 1e-6,
"FU=2 effect matches coefficient sum" = abs(te_fu2$EFFECT_SIZE - effect_fu2_expected) < 1e-6,
"FU=2 SE differs from naive (uses covariance)" = abs(te_fu2$SE - naive_se_fu2) > 1e-10
)
for (name in names(te_validation_lme4)) {
status <- if (te_validation_lme4[[name]]) "PASS" else "FAIL"
cat(status, " ", name, "\n", sep="")
if (!te_validation_lme4[[name]]) lme4_pass <- FALSE
}
cat("\n")
# ===== TEST 3: DNAm WITH DUAL PROBE SETS (NEW FUNCTIONALITY) =====
cat("TEST 3: DNAm Analysis with Dual Probe Sets (Multiple FU)\n")
cat("========================================================\n\n")
# Use full pheno data
pheno_dnam <- pheno
cat("Running DNAm Analysis (expects warnings about missing probes)\n")
results_dnam <- FAST_omics_WAS(
pheno = pheno_dnam,
omics = omics,
omics_type = "DNAm",
additional_covariates = additional_covariates
)
cat("\nResults Structure (DNAm)\n")
cat("  Top-level keys: ", paste(names(results_dnam), collapse=", "), "\n")
cat("  Full keys:      ", paste(names(results_dnam$full$all), collapse=", "), "\n")
cat("  Filtered keys:  ", paste(names(results_dnam$filtered$all), collapse=", "), "\n\n")
# Check full probe set results
cat("Full Probe Set Results\n")
if (!is.null(results_dnam$full$all$coefficients)) {
res_full <- results_dnam$full$all$coefficients
cat("  Coefficients rows: ", nrow(res_full), "\n")
cat("  Analytes:          ", length(unique(res_full$ANALYTE_NAME)), "\n")
cat("  Columns:           ", paste(colnames(res_full), collapse=", "), "\n\n")
}
# Check filtered probe set results
cat("Filtered Probe Set Results\n")
if (!is.null(results_dnam$filtered$all$coefficients)) {
res_filt <- results_dnam$filtered$all$coefficients
cat("  Coefficients rows: ", nrow(res_filt), "\n")
cat("  Analytes:          ", length(unique(res_filt$ANALYTE_NAME)), "\n\n")
}
cat("Validation Checks (DNAm Dual Probe Sets)\n")
# Get analyte counts for comparison
full_analytes <- if (!is.null(results_dnam$full$all$coefficients)) length(unique(results_dnam$full$all$coefficients$ANALYTE_NAME)) else 0
filtered_analytes <- if (!is.null(results_dnam$filtered$all$coefficients)) length(unique(results_dnam$filtered$all$coefficients$ANALYTE_NAME)) else 0
checks_dnam <- list(
"Has 'full' key" = "full" %in% names(results_dnam),
"Has 'filtered' key" = "filtered" %in% names(results_dnam),
"Full has all/male/female" = all(c("all", "male", "female") %in% names(results_dnam$full)),
"Filtered has all/male/female" = all(c("all", "male", "female") %in% names(results_dnam$filtered)),
"Full coefficients exist" = !is.null(results_dnam$full$all$coefficients),
"Filtered coefficients exist" = !is.null(results_dnam$filtered$all$coefficients),
"Full has expected rows" = nrow(results_dnam$full$all$coefficients) > 0,
"Filtered has expected rows" = nrow(results_dnam$filtered$all$coefficients) > 0,
"Filtered <= Full analytes" = filtered_analytes <= full_analytes,
"Full has effect sizes" = all(!is.na(results_dnam$full$all$coefficients$EFFECT_SIZE)),
"Filtered has effect sizes" = all(!is.na(results_dnam$filtered$all$coefficients$EFFECT_SIZE)),
"Full has BH correction" = "BH_P_VALUE" %in% colnames(results_dnam$full$all$coefficients),
"Filtered has BH correction" = "BH_P_VALUE" %in% colnames(results_dnam$filtered$all$coefficients),
"Full sex stratification" = !is.null(results_dnam$full$male$coefficients) && !is.null(results_dnam$full$female$coefficients),
"Filtered sex stratification" = !is.null(results_dnam$filtered$male$coefficients) && !is.null(results_dnam$filtered$female$coefficients),
"Treatment effects NULL (LIMMA TBD)" = is.null(results_dnam$full$all$treatment_effects)
)
dnam_pass <- TRUE
for (name in names(checks_dnam)) {
status <- if (checks_dnam[[name]]) "PASS" else "FAIL"
cat(status, " ", name, "\n", sep="")
if (!checks_dnam[[name]]) dnam_pass <- FALSE
}
cat("\n")
# ===== TEST 4: DNAm WITH SINGLE FU (EDGE CASE) =====
cat("TEST 4: DNAm Analysis with Dual Probe Sets (Single FU)\n")
cat("======================================================\n\n")
# Use single FU pheno data
pheno_dnam_single <- pheno_lm
cat("Running DNAm Analysis with Single FU (expects warnings about missing probes)\n")
results_dnam_single <- FAST_omics_WAS(
pheno = pheno_dnam_single,
omics = omics,
omics_type = "DNAm",
additional_covariates = additional_covariates
)
cat("\nResults Structure (DNAm Single FU)\n")
cat("  Top-level keys: ", paste(names(results_dnam_single), collapse=", "), "\n\n")
cat("Validation Checks (DNAm Single FU)\n")
checks_dnam_single <- list(
"Has 'full' key" = "full" %in% names(results_dnam_single),
"Has 'filtered' key" = "filtered" %in% names(results_dnam_single),
"Full coefficients exist" = !is.null(results_dnam_single$full$all$coefficients),
"Filtered coefficients exist" = !is.null(results_dnam_single$filtered$all$coefficients),
"Full FU level is 1" = all(results_dnam_single$full$all$coefficients$FU == 1),
"Filtered FU level is 1" = all(results_dnam_single$filtered$all$coefficients$FU == 1),
"Full has BH correction" = "BH_P_VALUE" %in% colnames(results_dnam_single$full$all$coefficients),
"Filtered has BH correction" = "BH_P_VALUE" %in% colnames(results_dnam_single$filtered$all$coefficients)
)
dnam_single_pass <- TRUE
for (name in names(checks_dnam_single)) {
status <- if (checks_dnam_single[[name]]) "PASS" else "FAIL"
cat(status, " ", name, "\n", sep="")
if (!checks_dnam_single[[name]]) dnam_single_pass <- FALSE
}
cat("\n")
# ===== SUMMARY =====
cat("Summary\n")
cat("=======\n\n")
cat("Test Results:\n")
cat("  LM (Single FU, Proteomics):      ", if (lm_pass) "PASS" else "FAIL", "\n")
cat("  LME4 (Multiple FU, Proteomics):  ", if (lme4_pass) "PASS" else "FAIL", "\n")
cat("  DNAm Dual Probe Sets (Multi FU): ", if (dnam_pass) "PASS" else "FAIL", "\n")
cat("  DNAm Dual Probe Sets (Single FU):", if (dnam_single_pass) "PASS" else "FAIL", "\n\n")
all_pass <- lm_pass && lme4_pass && dnam_pass && dnam_single_pass
if (all_pass) {
cat("ALL TESTS PASSED\n")
} else {
cat("SOME TESTS FAILED\n")
}
View(res_filt)
View(results_lme4)
# ===== TEST FOR MAIN.R =====
#
# Tests existing functionality (LM, LME4) plus new DNAm dual probe set feature
# - LM:    Single FU (Proteomics/Metabolomics)
# - LME4:  Multiple FU (Proteomics/Metabolomics)
# - DNAm:  Dual probe sets (full + filtered) with nested output structure
source("main.R")
require(lme4)
require(limma)
# ===== SETUP =====
cat("Test Suite for main.R\n")
cat("==========================\n\n")
# Load raw data
pheno_raw <- readRDS("PracticeData/pheno_example.rds")
omics_raw <- readRDS("PracticeData/synth_small_betas.rds")
# Convert haven_labelled columns if present
if (any(sapply(pheno_raw, function(x) inherits(x, "haven_labelled")))) {
for (col in names(pheno_raw)) {
if (inherits(pheno_raw[[col]], "haven_labelled")) {
raw_values <- as.vector(pheno_raw[[col]])
numeric_attempt <- tryCatch(as.numeric(raw_values), error = function(e) NA)
if (!all(is.na(numeric_attempt))) {
pheno_raw[[col]] <- numeric_attempt
} else {
pheno_raw[[col]] <- as.character(raw_values)
}
}
}
}
# Prepare pheno data
pheno <- pheno_raw[!duplicated(pheno_raw$SAMPLE_ID), ]
pheno <- pheno[complete.cases(pheno[, c("SAMPLE_ID", "FU", "SUBJECT_ID", "FEMALE", "CONTROL_STATUS")]), ]
# Prepare omics data - ensure overlap with both probe lists for DNAm tests
analyte_names <- rownames(omics_raw)
sample_names <- colnames(omics_raw)
omics_full <- as.data.frame(omics_raw)
colnames(omics_full) <- sample_names
omics_full <- cbind(ANALYTE_NAME = analyte_names, omics_full, stringsAsFactors = FALSE)
# Load probe lists to ensure test data has overlap with both
full_probes <- readRDS("Data/FAST_epicv1_epicv2_probe_list.rds")
filtered_probes <- readRDS("Data/FAST_epicv1_epicv2_sugden_TruD_probe_list.rds")
# Find probes in our data that are in each list
in_full <- omics_full$ANALYTE_NAME %in% full_probes
in_filtered <- omics_full$ANALYTE_NAME %in% filtered_probes
cat("Probe overlap in raw data:\n")
cat("  In full list:     ", sum(in_full), "\n")
cat("  In filtered list: ", sum(in_filtered), "\n\n")
# Create test subset: 100 from filtered (if available) + 400 from full-only
filtered_probes_available <- omics_full[in_filtered, ]
full_only_probes <- omics_full[in_full & !in_filtered, ]
n_filtered <- min(100, nrow(filtered_probes_available))
n_full_only <- min(400, nrow(full_only_probes))
omics <- rbind(
filtered_probes_available[1:n_filtered, ],
full_only_probes[1:n_full_only, ]
)
cat("Test subset created:\n")
cat("  From filtered list: ", n_filtered, "\n")
cat("  From full-only:     ", n_full_only, "\n")
cat("  Total:              ", nrow(omics), "\n\n")
additional_covariates <- c("agebl", "agevis", "ethnic", "race3", "mbmi")
cat("Data Loaded\n")
cat("  Pheno:     ", nrow(pheno), "samples, FU:", paste(sort(unique(pheno$FU)), collapse=", "), "\n")
cat("  Omics:     ", nrow(omics), "analytes\n")
cat("  Covariates:", paste(additional_covariates, collapse=", "), "\n")
cat("  (Omics subset ensures overlap with both DNAm probe lists)\n\n")
# ===== TEST 1: LINEAR REGRESSION (LM) =====
cat("TEST 1: Linear Regression (LM, Single FU)\n")
cat("==========================================\n\n")
# Filter to single FU (0 and 1 only)
pheno_lm <- pheno[pheno$FU %in% c(0, 1), ]
pheno_lm <- pheno_lm[!duplicated(pheno_lm$SAMPLE_ID), ]
cat("Running LM Analysis\n")
results_lm <- FAST_omics_WAS(
pheno = pheno_lm,
omics = omics,
omics_type = "Proteomics",
additional_covariates = additional_covariates
)
cat("Results (LM)\n")
if (!is.null(results_lm$all$coefficients)) {
res <- results_lm$all$coefficients
cat("  Coefficients rows: ", nrow(res), "\n")
cat("  Analytes:          ", length(unique(res$ANALYTE_NAME)), "\n")
cat("  Columns:           ", paste(colnames(res), collapse=", "), "\n")
}
if (!is.null(results_lm$all$treatment_effects)) {
te <- results_lm$all$treatment_effects
cat("  Treatment effects: ", nrow(te), " rows\n")
cat("  FU levels:         ", paste(sort(unique(te$FU)), collapse=", "), "\n\n")
cat("Sample Treatment Effects (first 5 rows)\n")
print(head(te, 5))
cat("\n")
}
cat("Validation Checks (LM)\n")
checks_lm <- list(
"Coefficients exist" = !is.null(results_lm$all$coefficients),
"Coefficients have rows" = nrow(results_lm$all$coefficients) > 0,
"Coefficients have BH correction" = "BH_P_VALUE" %in% colnames(results_lm$all$coefficients),
"Treatment effects exist" = !is.null(results_lm$all$treatment_effects),
"Treatment effects have rows" = nrow(results_lm$all$treatment_effects) > 0,
"Treatment effects FU = 1" = all(results_lm$all$treatment_effects$FU == 1),
"Treatment effects have BH correction" = "BH_P_VALUE" %in% colnames(results_lm$all$treatment_effects),
"Sex stratification works" = !is.null(results_lm$male$coefficients) && !is.null(results_lm$female$coefficients),
"Output structure correct" = all(c("all", "male", "female") %in% names(results_lm))
)
lm_pass <- TRUE
for (name in names(checks_lm)) {
status <- if (checks_lm[[name]]) "PASS" else "FAIL"
cat(status, " ", name, "\n", sep="")
if (!checks_lm[[name]]) lm_pass <- FALSE
}
cat("\n")
# Validate treatment effects match CONTROL_STATUS coefficient (LM)
cat("Treatment Effect Validation (LM)\n")
coefs <- results_lm$all$coefficients
te <- results_lm$all$treatment_effects
# For each analyte, treatment effect should match CONTROL_STATUS coefficient
sample_analyte <- te$ANALYTE_NAME[1]
te_row <- te[te$ANALYTE_NAME == sample_analyte, ]
coef_row <- coefs[coefs$ANALYTE_NAME == sample_analyte & grepl("^CONTROL_STATUS", coefs$COEFFICIENT), ]
te_validation_lm <- list(
"Effect size matches CONTROL_STATUS" = abs(te_row$EFFECT_SIZE - coef_row$EFFECT_SIZE) < 1e-10,
"SE matches CONTROL_STATUS" = abs(te_row$SE - coef_row$SE) < 1e-10,
"P-value matches CONTROL_STATUS" = abs(te_row$P_VALUE - coef_row$P_VALUE) < 1e-10
)
for (name in names(te_validation_lm)) {
status <- if (te_validation_lm[[name]]) "PASS" else "FAIL"
cat(status, " ", name, "\n", sep="")
if (!te_validation_lm[[name]]) lm_pass <- FALSE
}
cat("\n")
# ===== TEST 2: LINEAR MIXED EFFECTS (LME4) =====
cat("TEST 2: Linear Mixed Effects (LME4, Multiple FU)\n")
cat("==============================================\n\n")
# Use full pheno data (all FU levels, including baseline)
pheno_lme4 <- pheno
cat("Running LME4 Analysis\n")
results_lme4 <- FAST_omics_WAS(
pheno = pheno_lme4,
omics = omics,
omics_type = "Proteomics",
additional_covariates = additional_covariates
)
cat("Results (LME4)\n")
if (!is.null(results_lme4$all$coefficients)) {
res <- results_lme4$all$coefficients
cat("  Coefficients rows: ", nrow(res), "\n")
cat("  Analytes:          ", length(unique(res$ANALYTE_NAME)), "\n")
cat("  Columns:           ", paste(colnames(res), collapse=", "), "\n")
}
if (!is.null(results_lme4$all$treatment_effects)) {
te <- results_lme4$all$treatment_effects
cat("  Treatment effects: ", nrow(te), " rows\n")
cat("  FU levels:         ", paste(sort(unique(te$FU)), collapse=", "), "\n\n")
cat("Sample Treatment Effects (first 5 rows)\n")
print(head(te, 5))
cat("\n")
}
cat("Validation Checks (LME4)\n")
checks_lme4 <- list(
"Coefficients exist" = !is.null(results_lme4$all$coefficients),
"Coefficients have rows" = nrow(results_lme4$all$coefficients) > 0,
"Coefficients have BH correction" = "BH_P_VALUE" %in% colnames(results_lme4$all$coefficients),
"Treatment effects exist" = !is.null(results_lme4$all$treatment_effects),
"Treatment effects have rows" = nrow(results_lme4$all$treatment_effects) > 0,
"Treatment effects FU levels" = all(sort(unique(results_lme4$all$treatment_effects$FU)) %in% c(1, 2)),
"Treatment effects have BH correction" = "BH_P_VALUE" %in% colnames(results_lme4$all$treatment_effects),
"Treatment effects have robust SEs" = all(!is.na(results_lme4$all$treatment_effects$SE)),
"Sex stratification works" = !is.null(results_lme4$male$coefficients) && !is.null(results_lme4$female$coefficients),
"Output structure correct" = all(c("all", "male", "female") %in% names(results_lme4))
)
lme4_pass <- TRUE
for (name in names(checks_lme4)) {
status <- if (checks_lme4[[name]]) "PASS" else "FAIL"
cat(status, " ", name, "\n", sep="")
if (!checks_lme4[[name]]) lme4_pass <- FALSE
}
cat("\n")
# Validate treatment effects are computed correctly (LME4)
cat("Treatment Effect Validation (LME4)\n")
coefs <- results_lme4$all$coefficients
te <- results_lme4$all$treatment_effects
# Pick a sample analyte
sample_analyte <- te$ANALYTE_NAME[1]
te_analyte <- te[te$ANALYTE_NAME == sample_analyte, ]
coefs_analyte <- coefs[coefs$ANALYTE_NAME == sample_analyte, ]
# Get relevant coefficients
ctrl_coef <- coefs_analyte[grepl("^CONTROL_STATUS[0-9]*$", coefs_analyte$COEFFICIENT), ]
interaction_coef <- coefs_analyte[grepl("CONTROL_STATUS.*:.*FU2", coefs_analyte$COEFFICIENT), ]
# Treatment effect at FU=1 should match CONTROL_STATUS coefficient
te_fu1 <- te_analyte[te_analyte$FU == 1, ]
effect_fu1_expected <- ctrl_coef$EFFECT_SIZE
# Treatment effect at FU=2 should equal CONTROL_STATUS + CONTROL_STATUS:FU2
te_fu2 <- te_analyte[te_analyte$FU == 2, ]
effect_fu2_expected <- ctrl_coef$EFFECT_SIZE + interaction_coef$EFFECT_SIZE
# Naive SE (assuming independence) for comparison
naive_se_fu2 <- sqrt(ctrl_coef$SE^2 + interaction_coef$SE^2)
cat("  Sample analyte: ", sample_analyte, "\n")
cat("  FU=1: emmeans=", round(te_fu1$EFFECT_SIZE, 6), " expected=", round(effect_fu1_expected, 6), "\n")
cat("  FU=2: emmeans=", round(te_fu2$EFFECT_SIZE, 6), " expected=", round(effect_fu2_expected, 6), "\n")
cat("  FU=2 SE: emmeans=", round(te_fu2$SE, 6), " naive=", round(naive_se_fu2, 6), "\n\n")
te_validation_lme4 <- list(
"FU=1 effect matches CONTROL_STATUS" = abs(te_fu1$EFFECT_SIZE - effect_fu1_expected) < 1e-6,
"FU=2 effect matches coefficient sum" = abs(te_fu2$EFFECT_SIZE - effect_fu2_expected) < 1e-6,
"FU=2 SE differs from naive (uses covariance)" = abs(te_fu2$SE - naive_se_fu2) > 1e-10
)
for (name in names(te_validation_lme4)) {
status <- if (te_validation_lme4[[name]]) "PASS" else "FAIL"
cat(status, " ", name, "\n", sep="")
if (!te_validation_lme4[[name]]) lme4_pass <- FALSE
}
cat("\n")
# ===== TEST 3: DNAm WITH DUAL PROBE SETS (NEW FUNCTIONALITY) =====
cat("TEST 3: DNAm Analysis with Dual Probe Sets (Multiple FU)\n")
cat("========================================================\n\n")
# Use full pheno data
pheno_dnam <- pheno
cat("Running DNAm Analysis (expects warnings about missing probes)\n")
results_dnam <- FAST_omics_WAS(
pheno = pheno_dnam,
omics = omics,
omics_type = "DNAm",
additional_covariates = additional_covariates
)
cat("\nResults Structure (DNAm)\n")
cat("  Top-level keys: ", paste(names(results_dnam), collapse=", "), "\n")
cat("  Full keys:      ", paste(names(results_dnam$full$all), collapse=", "), "\n")
cat("  Filtered keys:  ", paste(names(results_dnam$filtered$all), collapse=", "), "\n\n")
# Check full probe set results
cat("Full Probe Set Results\n")
if (!is.null(results_dnam$full$all$coefficients)) {
res_full <- results_dnam$full$all$coefficients
cat("  Coefficients rows: ", nrow(res_full), "\n")
cat("  Analytes:          ", length(unique(res_full$ANALYTE_NAME)), "\n")
